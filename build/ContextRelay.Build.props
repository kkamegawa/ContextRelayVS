<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    Shared MSBuild UsingTask definitions for ContextRelay build infrastructure.
    
    Contains C# implementations of build-time file manipulation tasks that replace
    PowerShell scripts, eliminating execution policy dependencies.
    
    Imported by:
    - src/ContextRelay.VSExtension.Package/ContextRelay.VSExtension.Package.csproj
    - src/ContextRelay.VSExtension/ContextRelay.VSExtension.csproj
  -->

  <!-- 
    PatchPkgdefFile Task: Performs regex-based modifications to pkgdef files
    
    Replaces two key patterns:
    1. IsInUnifiedSettings=1 → IsInUnifiedSettings=0 (keeps legacy options page visible)
    2. @="#0" → literal display names like "ContextRelay" (makes options tree readable)
    
    Parameters:
    - PkgdefPath: Full path to the pkgdef file to modify
  -->
  <UsingTask TaskName="PatchPkgdefFile" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <PkgdefPath ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.IO" />
      <Using Namespace="System.Text.RegularExpressions" />
      <Code>
        <![CDATA[
        try
        {
            string content = File.ReadAllText(PkgdefPath);

            // Regex 1: Set IsInUnifiedSettings from 1 to 0 to keep legacy options page visible
            content = Regex.Replace(
                content,
                @"(=hkcu,SOFTWARE\\Microsoft\\VisualStudio\\.*?\\ToolsOptions\\.*?)\s*\n\s*""IsInUnifiedSettings""=""dword:00000001""",
                "$1\r\n\"IsInUnifiedSettings\"=\"dword:00000000\"",
                RegexOptions.Multiline | RegexOptions.IgnoreCase
            );

            // Regex 2: Replace numeric resource references (@="#0") with literal display names
            content = Regex.Replace(content, @"@=""#0""", "@=\"ContextRelay\"", RegexOptions.IgnoreCase);
            content = Regex.Replace(content, @"@=""#1""", "@=\"General\"", RegexOptions.IgnoreCase);

            File.WriteAllText(PkgdefPath, content, new System.Text.UTF8Encoding(false));
            Log.LogMessage(MessageImportance.High, "Patched pkgdef file: {0}", PkgdefPath);
        }
        catch (Exception ex)
        {
            Log.LogError("Failed to patch pkgdef file {0}: {1}", PkgdefPath, ex.Message);
        }
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <!--
    InjectVsPackageAsset Task: Manipulates VSIX manifest XML
    
    Ensures the Microsoft.VisualStudio.VsPackage asset is injected into the manifest
    to properly register the pkgdef with Visual Studio.
    
    Parameters:
    - ManifestPath: Full path to the VSIX extension.vsixmanifest file
    - PkgdefFileName: Name of the pkgdef file (e.g., ContextRelay.VSExtension.Package.pkgdef)
  -->
  <UsingTask TaskName="InjectVsPackageAsset" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <ManifestPath ParameterType="System.String" Required="true" />
      <PkgdefFileName ParameterType="System.String" Required="true" />
      <SourceManifestPath ParameterType="System.String" Required="false" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.Xml" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Linq" />
      <Code>
        <![CDATA[
        try
        {
            const string ManifestNamespace = "http://schemas.microsoft.com/developer/vsx-schema/2011";

            void RemoveDirectChild(XmlElement root, string localName)
            {
                var existing = root.ChildNodes
                    .OfType<XmlNode>()
                    .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == localName && node.NamespaceURI == ManifestNamespace);
                if (existing != null)
                {
                    root.RemoveChild(existing);
                }
            }

            XmlElement EnsureSection(XmlDocument targetDocument, XmlElement targetRoot, string sectionName)
            {
                XmlElement existingSection = targetRoot.ChildNodes
                    .OfType<XmlNode>()
                    .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == sectionName && node.NamespaceURI == ManifestNamespace) as XmlElement;
                if (existingSection != null)
                {
                    return existingSection;
                }

                XmlElement newSection = targetDocument.CreateElement(sectionName, ManifestNamespace);
                if (sectionName == "Installation")
                {
                    XmlNode metadataNode = targetRoot.ChildNodes
                        .OfType<XmlNode>()
                        .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == "Metadata" && node.NamespaceURI == ManifestNamespace);
                    if (metadataNode != null)
                    {
                        targetRoot.InsertAfter(newSection, metadataNode);
                        return newSection;
                    }
                }

                if (sectionName == "Dependencies")
                {
                    XmlNode installationNode = targetRoot.ChildNodes
                        .OfType<XmlNode>()
                        .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == "Installation" && node.NamespaceURI == ManifestNamespace);
                    if (installationNode != null)
                    {
                        targetRoot.InsertAfter(newSection, installationNode);
                        return newSection;
                    }
                }

                if (sectionName == "Prerequisites")
                {
                    XmlNode dependenciesNode = targetRoot.ChildNodes
                        .OfType<XmlNode>()
                        .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == "Dependencies" && node.NamespaceURI == ManifestNamespace);
                    if (dependenciesNode != null)
                    {
                        targetRoot.InsertAfter(newSection, dependenciesNode);
                        return newSection;
                    }

                    XmlNode installationNode = targetRoot.ChildNodes
                        .OfType<XmlNode>()
                        .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == "Installation" && node.NamespaceURI == ManifestNamespace);
                    if (installationNode != null)
                    {
                        targetRoot.InsertAfter(newSection, installationNode);
                        return newSection;
                    }
                }

                XmlNode assetsNode = targetRoot.ChildNodes
                    .OfType<XmlNode>()
                    .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == "Assets" && node.NamespaceURI == ManifestNamespace);
                if (assetsNode != null)
                {
                    targetRoot.InsertBefore(newSection, assetsNode);
                    return newSection;
                }

                targetRoot.AppendChild(newSection);
                return newSection;
            }

            void SyncSection(XmlDocument targetDocument, XmlElement targetRoot, XmlDocument sourceDocument, string sectionName)
            {
                RemoveDirectChild(targetRoot, sectionName);

                XmlElement sourceRoot = sourceDocument.DocumentElement;
                XmlElement sourceSection = sourceRoot == null ? null : sourceRoot.ChildNodes
                    .OfType<XmlNode>()
                    .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == sectionName && node.NamespaceURI == ManifestNamespace) as XmlElement;

                if (sourceSection == null)
                {
                    return;
                }

                XmlNode importedNode = targetDocument.ImportNode(sourceSection, true);
                XmlElement sectionContainer = EnsureSection(targetDocument, targetRoot, sectionName);
                targetRoot.ReplaceChild(importedNode, sectionContainer);
            }

            // If SourceManifestPath is provided, verify it exists to prevent silent failures
            if (!string.IsNullOrEmpty(SourceManifestPath) && !File.Exists(SourceManifestPath))
            {
                Log.LogError("SourceManifestPath '{0}' does not exist; failing the build to prevent creating VSIX with unsynced manifest", SourceManifestPath);
                return false;
            }

            XmlDocument doc = new XmlDocument();
            doc.Load(ManifestPath);
            XmlNamespaceManager ns = new XmlNamespaceManager(doc.NameTable);
            ns.AddNamespace("x", ManifestNamespace);
            XmlElement root = doc.DocumentElement;
            if (root == null)
            {
                Log.LogError("Manifest '{0}' did not contain a document element", ManifestPath);
                return false;
            }

            if (!string.IsNullOrEmpty(SourceManifestPath))
            {
                XmlDocument sourceDoc = new XmlDocument();
                sourceDoc.Load(SourceManifestPath);
                SyncSection(doc, root, sourceDoc, "Installation");
                SyncSection(doc, root, sourceDoc, "Dependencies");
                SyncSection(doc, root, sourceDoc, "Prerequisites");
                Log.LogMessage(MessageImportance.High, "Synchronized manifest installation metadata from source manifest: {0}", SourceManifestPath);
            }

            // Ensure Assets element exists
            XmlElement assetsElement = EnsureSection(doc, root, "Assets");

            // Find or create Microsoft.VisualStudio.VsPackage asset
            XmlNode pkgAsset = doc.SelectSingleNode("//x:Asset[@Type='Microsoft.VisualStudio.VsPackage']", ns);
            if (pkgAsset == null)
            {
                pkgAsset = doc.CreateElement("Asset", ManifestNamespace);
                XmlElement pkgElement = (XmlElement)pkgAsset;
                pkgElement.SetAttribute("Type", "Microsoft.VisualStudio.VsPackage");
                pkgElement.SetAttribute("Path", PkgdefFileName);
                assetsElement.AppendChild(pkgAsset);
            }
            else
            {
                ((XmlElement)pkgAsset).SetAttribute("Path", PkgdefFileName);
            }

            doc.Save(ManifestPath);
            Log.LogMessage(MessageImportance.High, "Injected VsPackage asset into manifest: {0}", ManifestPath);
        }
        catch (Exception ex)
        {
            Log.LogError("Failed to inject VsPackage asset into manifest {0}: {1}", ManifestPath, ex.Message);
        }
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <!--
    RemoveDuplicateExperimentalExtensions Task: Cleans up duplicate VS extension deployments
    
    Visual Studio may leave multiple hashed extension folders for the same VSIX ID.
    This task keeps only the newest deployment and removes older duplicates, then
    touches extensions.configurationchanged to invalidate the VS cache.
    
    Parameters:
    - VsLocalAppData: Path to VS local AppData root (e.g., %LocalAppData%\Microsoft\VisualStudio)
    - RootSuffix: Experimental instance root suffix (default: Exp)
    - ExtensionId: VSIX identity to deduplicate
  -->
  <UsingTask TaskName="RemoveDuplicateExperimentalExtensions" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <VsLocalAppData ParameterType="System.String" Required="true" />
      <RootSuffix ParameterType="System.String" Required="false" />
      <ExtensionId ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.IO" />
      <Using Namespace="System.Xml" />
      <Using Namespace="System.Text.RegularExpressions" />
      <Using Namespace="System.Collections.Generic" />
      <Using Namespace="System.Linq" />
      <Code>
        <![CDATA[
        try
        {
            string rootSuffix = string.IsNullOrEmpty(RootSuffix) ? "Exp" : RootSuffix;
            string expPattern = @"\d+\.\d+_[0-9a-fA-F]+" + Regex.Escape(rootSuffix) + "$";

            DirectoryInfo vsAppData = new DirectoryInfo(VsLocalAppData);
            if (!vsAppData.Exists)
            {
                Log.LogWarning("Visual Studio AppData path not found: {0}", VsLocalAppData);
            }

            // Find all experimental instance directories
            var expDirs = vsAppData.GetDirectories()
                .Where(d => Regex.IsMatch(d.Name, expPattern))
                .ToList();

            if (expDirs.Count == 0)
            {
                Log.LogMessage(MessageImportance.Low, "No experimental instance directories found under {0}", VsLocalAppData);
            }

            foreach (DirectoryInfo expDir in expDirs)
            {
                string extensionsPath = Path.Combine(expDir.FullName, "Extensions");
                string vsExtensionsPath = Path.Combine(expDir.FullName, "VSExtensions");
                var searchRoots = new List<string>();

                if (Directory.Exists(extensionsPath))
                {
                    searchRoots.Add(extensionsPath);
                }

                if (Directory.Exists(vsExtensionsPath))
                {
                    searchRoots.Add(vsExtensionsPath);
                }

                if (searchRoots.Count == 0)
                {
                    continue;
                }

                // Collect all deployments that declare the same extension ID across both roots.
                var matchingDirs = new Dictionary<string, DateTime>(StringComparer.OrdinalIgnoreCase);
                foreach (string rootPath in searchRoots)
                {
                    foreach (string manifestPath in Directory.EnumerateFiles(rootPath, "extension.vsixmanifest", SearchOption.AllDirectories))
                    {
                        try
                        {
                            string manifestContent = File.ReadAllText(manifestPath);
                            if (!manifestContent.Contains("Id=\"" + ExtensionId + "\""))
                            {
                                continue;
                            }

                            string candidateDir = Path.GetDirectoryName(manifestPath);
                            if (string.IsNullOrWhiteSpace(candidateDir))
                            {
                                continue;
                            }

                            string normalizedCandidateDir = Path.GetFullPath(candidateDir)
                                .TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
                            matchingDirs[normalizedCandidateDir] = Directory.GetLastWriteTimeUtc(normalizedCandidateDir);
                        }
                        catch (Exception ex)
                        {
                            Log.LogWarning("Failed to inspect manifest {0}: {1}", manifestPath, ex.Message);
                        }
                    }
                }

                if (matchingDirs.Count > 1)
                {
                    string keepDir = matchingDirs
                        .OrderByDescending(x => x.Value)
                        .First()
                        .Key;

                    foreach (string candidateDir in matchingDirs.Keys)
                    {
                        if (StringComparer.OrdinalIgnoreCase.Equals(candidateDir, keepDir))
                        {
                            continue;
                        }

                        try
                        {
                            Directory.Delete(candidateDir, recursive: true);
                            Log.LogMessage(MessageImportance.High, "Removed duplicate extension deployment: {0}", candidateDir);
                        }
                        catch (Exception ex)
                        {
                            Log.LogWarning("Failed to remove duplicate extension {0}: {1}", candidateDir, ex.Message);
                        }
                    }
                }

                if (Directory.Exists(extensionsPath))
                {
                    // Touch extensions.configurationchanged to invalidate cache
                    try
                    {
                        string changeFile = Path.Combine(extensionsPath, "extensions.configurationchanged");
                        File.WriteAllText(changeFile, DateTime.UtcNow.ToString("o"));
                        Log.LogMessage(MessageImportance.High, "Touched extensions.configurationchanged: {0}", changeFile);
                    }
                    catch (Exception ex)
                    {
                        Log.LogWarning("Failed to touch extensions.configurationchanged: {0}", ex.Message);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Log.LogError("RemoveDuplicateExperimentalExtensions task failed: {0}", ex.Message);
        }
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <!--
    DeployInProcPackage Task: Deploys in-proc VSSDK package to VS Extensions folder
    
    The OOP Extensibility host deploys to VSExtensions\, but the pkgdef engine
    only scans Extensions\ (user) and Program Files (system). This task bridges the gap
    by placing the pkgdef and DLL in the Extensions folder so VS can register
    Tools > Options pages at startup.
    
    Parameters:
    - PkgdefPath: Full path to the generated pkgdef file
    - DllPath: Full path to the compiled package DLL
    - VsLocalAppData: Path to VS local AppData root
    - RootSuffix: Experimental instance root suffix (default: Exp)
    - SupportingAssemblies: Optional semicolon-separated list of supporting assembly paths
    - ExtensionId: Optional VSIX identity; if provided, supporting assemblies also copied to main extension
  -->
  <UsingTask TaskName="DeployInProcPackage" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <PkgdefPath ParameterType="System.String" Required="true" />
      <DllPath ParameterType="System.String" Required="true" />
      <VsLocalAppData ParameterType="System.String" Required="true" />
      <RootSuffix ParameterType="System.String" Required="false" />
      <SupportingAssemblies ParameterType="System.String" Required="false" />
      <ExtensionId ParameterType="System.String" Required="false" />
      <PublisherName ParameterType="System.String" Required="false" />
      <SidecarName ParameterType="System.String" Required="false" />
      <SidecarVersion ParameterType="System.String" Required="false" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.IO" />
      <Using Namespace="System.Xml" />
      <Using Namespace="System.Text.RegularExpressions" />
      <Using Namespace="System.Collections.Generic" />
      <Using Namespace="System.Linq" />
      <Code>
        <![CDATA[
        try
        {
            string rootSuffix = string.IsNullOrEmpty(RootSuffix) ? "Exp" : RootSuffix;
            string publisherName = string.IsNullOrWhiteSpace(PublisherName) ? "KazushiKamegawa" : PublisherName.Trim();
            string sidecarName = string.IsNullOrWhiteSpace(SidecarName) ? "ContextRelay.Package" : SidecarName.Trim();
            string sidecarVersion = string.IsNullOrWhiteSpace(SidecarVersion) ? "0.3.0.0" : SidecarVersion.Trim();
            string expPattern = @"\d+\.\d+_[0-9a-fA-F]+" + Regex.Escape(rootSuffix) + "$";

            DirectoryInfo vsAppData = new DirectoryInfo(VsLocalAppData);
            if (!vsAppData.Exists)
            {
                Log.LogWarning("Visual Studio AppData path not found: {0}", VsLocalAppData);
            }

            // Parse supporting assemblies (semicolon-separated)
            var supportingAssemblies = string.IsNullOrWhiteSpace(SupportingAssemblies)
                ? new List<string>()
                : SupportingAssemblies.Split(new[] { ';' }, System.StringSplitOptions.RemoveEmptyEntries)
                    .Select(s => s.Trim())
                    .Where(s => !string.IsNullOrWhiteSpace(s))
                    .ToList();

            // Find experimental instance directory
            var expDirs = vsAppData.GetDirectories()
                .Where(d => Regex.IsMatch(d.Name, expPattern))
                .ToList();

            if (expDirs.Count == 0)
            {
                Log.LogWarning("No experimental instance directory found under {0} matching *{1}", VsLocalAppData, rootSuffix);
            }

            foreach (DirectoryInfo expDir in expDirs)
            {
                string extensionsPath = Path.Combine(expDir.FullName, "Extensions");
                if (!Directory.Exists(extensionsPath))
                {
                    Directory.CreateDirectory(extensionsPath);
                    Log.LogMessage(MessageImportance.High, "Created Extensions folder: {0}", extensionsPath);
                }

                // Old deployments incorrectly used the Extensions-<instance> cache folder.
                // Keep the path only so those stale deployments can be removed.
                string expName = expDir.Name.Replace(rootSuffix, "");
                string legacySubDirPath = Path.Combine(extensionsPath, "Extensions-" + expName);

                string sidecarExtensionId = string.IsNullOrWhiteSpace(ExtensionId)
                    ? "ContextRelayVS.kkamegawa.d0dd4dd5-7d88-4b80-8d4d-9dd18fa4cf11.Package"
                    : ExtensionId + ".Package";

                // Mirror the standard VSIX installer folder layout so Experimental Instance
                // registration uses the same discovery conventions as an installed extension.
                string targetDir = Path.Combine(extensionsPath, publisherName, sidecarName, sidecarVersion);
                string fullTargetDir = Path.GetFullPath(targetDir).TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
                var staleSidecarDirs = new List<string>
                {
                    Path.Combine(extensionsPath, "ContextRelay.Package"),
                    Path.Combine(legacySubDirPath, "ContextRelay.Package"),
                    Path.Combine(legacySubDirPath, publisherName, sidecarName),
                    Path.Combine(extensionsPath, publisherName, sidecarName)
                };

                foreach (string candidateRoot in new[] { extensionsPath, legacySubDirPath }.Where(Directory.Exists))
                {
                    foreach (string candidateManifest in Directory.EnumerateFiles(candidateRoot, "extension.vsixmanifest", SearchOption.AllDirectories))
                    {
                        string candidateDir = Path.GetDirectoryName(candidateManifest);
                        string fullCandidateDir = Path.GetFullPath(candidateDir).TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
                        if (StringComparer.OrdinalIgnoreCase.Equals(fullCandidateDir, fullTargetDir))
                        {
                            continue;
                        }

                        try
                        {
                            string candidateManifestContent = File.ReadAllText(candidateManifest);
                            bool isCurrentSidecar = candidateManifestContent.Contains("Id=\"" + sidecarExtensionId + "\"");

                            // Never treat the main hybrid extension deployment as disposable sidecar content.
                            // The main extension legitimately references the package pkgdef in its manifest,
                            // so sidecar cleanup must key off the sidecar extension ID only.
                            if (isCurrentSidecar)
                            {
                                staleSidecarDirs.Add(candidateDir);
                            }
                        }
                        catch (Exception ex)
                        {
                            Log.LogWarning("Failed to inspect sidecar manifest {0}: {1}", candidateManifest, ex.Message);
                        }
                    }
                }

                foreach (string staleDir in staleSidecarDirs.Distinct(StringComparer.OrdinalIgnoreCase))
                {
                    if (Directory.Exists(staleDir))
                    {
                        Directory.Delete(staleDir, recursive: true);
                        Log.LogMessage(MessageImportance.High, "Removed stale sidecar deployment: {0}", staleDir);
                    }
                }

                string stalePublisherDir = Path.Combine(legacySubDirPath, publisherName);
                if (Directory.Exists(stalePublisherDir) && !Directory.EnumerateFileSystemEntries(stalePublisherDir).Any())
                {
                    Directory.Delete(stalePublisherDir);
                    Log.LogMessage(MessageImportance.High, "Removed empty sidecar publisher folder: {0}", stalePublisherDir);
                }

                string publisherRoot = Path.Combine(extensionsPath, publisherName);
                if (Directory.Exists(publisherRoot) && !Directory.EnumerateFileSystemEntries(publisherRoot).Any())
                {
                    Directory.Delete(publisherRoot);
                    Log.LogMessage(MessageImportance.High, "Removed empty sidecar publisher root: {0}", publisherRoot);
                }

                if (Directory.Exists(targetDir))
                {
                    Directory.Delete(targetDir, recursive: true);
                }

                Directory.CreateDirectory(targetDir);

                // Copy pkgdef
                if (File.Exists(PkgdefPath))
                {
                    string destPkgdef = Path.Combine(targetDir, Path.GetFileName(PkgdefPath));
                    File.Copy(PkgdefPath, destPkgdef, overwrite: true);
                    Log.LogMessage(MessageImportance.High, "Copied pkgdef -> {0}", targetDir);
                }
                else
                {
                    Log.LogWarning("pkgdef not found: {0}", PkgdefPath);
                }

                // Copy DLL
                if (File.Exists(DllPath))
                {
                    string destDll = Path.Combine(targetDir, Path.GetFileName(DllPath));
                    File.Copy(DllPath, destDll, overwrite: true);
                    Log.LogMessage(MessageImportance.High, "Copied DLL    -> {0}", targetDir);
                }
                else
                {
                    Log.LogWarning("DLL not found: {0}", DllPath);
                }

                // Copy supporting assemblies
                foreach (string assemblyPath in supportingAssemblies)
                {
                    if (File.Exists(assemblyPath))
                    {
                        string destAssembly = Path.Combine(targetDir, Path.GetFileName(assemblyPath));
                        File.Copy(assemblyPath, destAssembly, overwrite: true);
                        Log.LogMessage(MessageImportance.High, "Copied dependency -> {0}", destAssembly);
                    }
                    else if (!string.IsNullOrWhiteSpace(assemblyPath))
                    {
                        Log.LogWarning("Dependency not found: {0}", assemblyPath);
                    }
                }

                // Write extension.vsixmanifest
                string manifestContent = $@"<PackageManifest Version=""2.0.0"" xmlns=""http://schemas.microsoft.com/developer/vsx-schema/2011"">
  <Metadata>
    <Identity Id=""{sidecarExtensionId}"" Version=""{sidecarVersion}"" Language=""en-US"" Publisher=""{publisherName}"" />
    <DisplayName>ContextRelay for Visual Studio (Package)</DisplayName>
    <Description xml:space=""preserve"">In-proc VSSDK package for ContextRelay Tools &gt; Options registration.</Description>
  </Metadata>
  <Installation ExtensionType=""VSSDK"">
    <InstallationTarget Id=""Microsoft.VisualStudio.Enterprise"" Version=""[17.9,)"">
      <ProductArchitecture>amd64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id=""Microsoft.VisualStudio.Enterprise"" Version=""[17.9,)"">
      <ProductArchitecture>arm64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id=""Microsoft.VisualStudio.Pro"" Version=""[17.9,)"">
      <ProductArchitecture>amd64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id=""Microsoft.VisualStudio.Pro"" Version=""[17.9,)"">
      <ProductArchitecture>arm64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id=""Microsoft.VisualStudio.Community"" Version=""[17.9,)"">
      <ProductArchitecture>amd64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id=""Microsoft.VisualStudio.Community"" Version=""[17.9,)"">
      <ProductArchitecture>arm64</ProductArchitecture>
    </InstallationTarget>
  </Installation>
  <Dependencies />
  <Prerequisites>
    <Prerequisite Id=""Microsoft.VisualStudio.Component.CoreEditor"" Version=""[17.9,)"" DisplayName=""Visual Studio core editor"" />
  </Prerequisites>
  <Assets>
    <Asset Type=""Microsoft.VisualStudio.VsPackage"" Path=""ContextRelay.VSExtension.Package.pkgdef"" />
  </Assets>
</PackageManifest>";
                string manifestPath = Path.Combine(targetDir, "extension.vsixmanifest");
                File.WriteAllText(manifestPath, manifestContent, System.Text.Encoding.UTF8);
                Log.LogMessage(MessageImportance.High, "Wrote extension.vsixmanifest -> {0}", targetDir);

                // Touch extensions.configurationchanged to invalidate cache
                string changeFile = Path.Combine(extensionsPath, "extensions.configurationchanged");
                File.WriteAllText(changeFile, DateTime.UtcNow.ToString("o"));
                Log.LogMessage(MessageImportance.High, "Touched extensions.configurationchanged");

                // If ExtensionId provided, copy supporting assemblies to main extension deployment
                if (!string.IsNullOrWhiteSpace(ExtensionId))
                {
                     var mainExtDirs = new List<string>();
                     foreach (string rootPath in new[] { extensionsPath, Path.Combine(expDir.FullName, "VSExtensions") }.Where(Directory.Exists))
                     {
                         foreach (string mPath in Directory.EnumerateFiles(rootPath, "extension.vsixmanifest", SearchOption.AllDirectories))
                         {
                             try
                             {
                                 string mContent = File.ReadAllText(mPath);
                                 if (mContent.Contains("Id=\"" + ExtensionId + "\""))
                                 {
                                     string mainExtDir = Path.GetDirectoryName(mPath);
                                     if (!string.IsNullOrWhiteSpace(mainExtDir))
                                     {
                                         mainExtDirs.Add(mainExtDir);
                                     }
                                 }
                             }
                             catch (Exception ex)
                             {
                                 Log.LogWarning("Failed to check manifest {0}: {1}", mPath, ex.Message);
                             }
                         }
                     }

                     foreach (string mainExtDir in mainExtDirs.Distinct(StringComparer.OrdinalIgnoreCase))
                     {
                         foreach (string assemblyPath in supportingAssemblies)
                         {
                             if (File.Exists(assemblyPath))
                             {
                                string destAssembly = Path.Combine(mainExtDir, Path.GetFileName(assemblyPath));
                                File.Copy(assemblyPath, destAssembly, overwrite: true);
                                Log.LogMessage(MessageImportance.High, "Copied dependency -> {0}", destAssembly);
                            }
                        }
                    }
                }
            }

            Log.LogMessage(MessageImportance.High, "DeployInProcPackage complete");
        }
        catch (Exception ex)
        {
            Log.LogError("DeployInProcPackage task failed: {0}", ex.Message);
        }
        ]]>
      </Code>
    </Task>
  </UsingTask>
</Project>


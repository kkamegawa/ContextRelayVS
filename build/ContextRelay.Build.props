<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    Shared MSBuild UsingTask definitions for ContextRelay build infrastructure.
    
    Contains C# implementations of build-time file manipulation tasks that replace
    PowerShell scripts, eliminating execution policy dependencies.
    
    Imported by:
    - src/ContextRelay.VSExtension.Package/ContextRelay.VSExtension.Package.csproj
    - src/ContextRelay.VSExtension/ContextRelay.VSExtension.csproj
  -->

  <!-- 
    PatchPkgdefFile Task: Performs regex-based modifications to pkgdef files
    
    Replaces two key patterns:
    1. IsInUnifiedSettings=1 → IsInUnifiedSettings=0 (keeps legacy options page visible)
    2. @="#0" → literal display names like "ContextRelay" (makes options tree readable)
    
    Parameters:
    - PkgdefPath: Full path to the pkgdef file to modify
  -->
  <UsingTask TaskName="PatchPkgdefFile" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <PkgdefPath ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.IO" />
      <Using Namespace="System.Text.RegularExpressions" />
      <Code>
        <![CDATA[
        try
        {
            string content = File.ReadAllText(PkgdefPath);

            // Regex 1: Set IsInUnifiedSettings from 1 to 0 to keep legacy options page visible
            content = Regex.Replace(
                content,
                @"(=hkcu,SOFTWARE\\Microsoft\\VisualStudio\\.*?\\ToolsOptions\\.*?)\s*\n\s*""IsInUnifiedSettings""=""dword:00000001""",
                "$1\r\n\"IsInUnifiedSettings\"=\"dword:00000000\"",
                RegexOptions.Multiline | RegexOptions.IgnoreCase
            );

            // Regex 2: Replace numeric resource references (@="#0") with literal display names
            content = Regex.Replace(content, @"@=""#0""", "@=\"ContextRelay\"", RegexOptions.IgnoreCase);
            content = Regex.Replace(content, @"@=""#1""", "@=\"General\"", RegexOptions.IgnoreCase);

            File.WriteAllText(PkgdefPath, content, new System.Text.UTF8Encoding(false));
            Log.LogMessage(MessageImportance.High, "Patched pkgdef file: {0}", PkgdefPath);
        }
        catch (Exception ex)
        {
            Log.LogError("Failed to patch pkgdef file {0}: {1}", PkgdefPath, ex.Message);
        }
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <!--
    InjectVsPackageAsset Task: Manipulates VSIX manifest XML
    
    Ensures the Microsoft.VisualStudio.VsPackage asset is injected into the manifest
    to properly register the pkgdef with Visual Studio.
    
    Parameters:
    - ManifestPath: Full path to the VSIX extension.vsixmanifest file
    - PkgdefFileName: Name of the pkgdef file (e.g., ContextRelay.VSExtension.Package.pkgdef)
  -->
  <UsingTask TaskName="InjectVsPackageAsset" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <ManifestPath ParameterType="System.String" Required="true" />
      <PkgdefFileName ParameterType="System.String" Required="true" />
      <SourceManifestPath ParameterType="System.String" Required="false" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.Xml" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Linq" />
      <Code>
        <![CDATA[
        try
        {
            const string ManifestNamespace = "http://schemas.microsoft.com/developer/vsx-schema/2011";

            void RemoveDirectChild(XmlElement root, string localName)
            {
                var existing = root.ChildNodes
                    .OfType<XmlNode>()
                    .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == localName && node.NamespaceURI == ManifestNamespace);
                if (existing != null)
                {
                    root.RemoveChild(existing);
                }
            }

            XmlElement EnsureSection(XmlDocument targetDocument, XmlElement targetRoot, string sectionName)
            {
                XmlElement existingSection = targetRoot.ChildNodes
                    .OfType<XmlNode>()
                    .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == sectionName && node.NamespaceURI == ManifestNamespace) as XmlElement;
                if (existingSection != null)
                {
                    return existingSection;
                }

                XmlElement newSection = targetDocument.CreateElement(sectionName, ManifestNamespace);
                if (sectionName == "Installation")
                {
                    XmlNode metadataNode = targetRoot.ChildNodes
                        .OfType<XmlNode>()
                        .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == "Metadata" && node.NamespaceURI == ManifestNamespace);
                    if (metadataNode != null)
                    {
                        targetRoot.InsertAfter(newSection, metadataNode);
                        return newSection;
                    }
                }

                if (sectionName == "Dependencies")
                {
                    XmlNode installationNode = targetRoot.ChildNodes
                        .OfType<XmlNode>()
                        .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == "Installation" && node.NamespaceURI == ManifestNamespace);
                    if (installationNode != null)
                    {
                        targetRoot.InsertAfter(newSection, installationNode);
                        return newSection;
                    }
                }

                if (sectionName == "Prerequisites")
                {
                    XmlNode dependenciesNode = targetRoot.ChildNodes
                        .OfType<XmlNode>()
                        .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == "Dependencies" && node.NamespaceURI == ManifestNamespace);
                    if (dependenciesNode != null)
                    {
                        targetRoot.InsertAfter(newSection, dependenciesNode);
                        return newSection;
                    }

                    XmlNode installationNode = targetRoot.ChildNodes
                        .OfType<XmlNode>()
                        .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == "Installation" && node.NamespaceURI == ManifestNamespace);
                    if (installationNode != null)
                    {
                        targetRoot.InsertAfter(newSection, installationNode);
                        return newSection;
                    }
                }

                XmlNode assetsNode = targetRoot.ChildNodes
                    .OfType<XmlNode>()
                    .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == "Assets" && node.NamespaceURI == ManifestNamespace);
                if (assetsNode != null)
                {
                    targetRoot.InsertBefore(newSection, assetsNode);
                    return newSection;
                }

                targetRoot.AppendChild(newSection);
                return newSection;
            }

            void SyncSection(XmlDocument targetDocument, XmlElement targetRoot, XmlDocument sourceDocument, string sectionName)
            {
                RemoveDirectChild(targetRoot, sectionName);

                XmlElement sourceRoot = sourceDocument.DocumentElement;
                XmlElement sourceSection = sourceRoot == null ? null : sourceRoot.ChildNodes
                    .OfType<XmlNode>()
                    .FirstOrDefault(node => node.NodeType == XmlNodeType.Element && node.LocalName == sectionName && node.NamespaceURI == ManifestNamespace) as XmlElement;

                if (sourceSection == null)
                {
                    return;
                }

                XmlNode importedNode = targetDocument.ImportNode(sourceSection, true);
                XmlElement sectionContainer = EnsureSection(targetDocument, targetRoot, sectionName);
                targetRoot.ReplaceChild(importedNode, sectionContainer);
            }

            // If SourceManifestPath is provided, verify it exists to prevent silent failures
            if (!string.IsNullOrEmpty(SourceManifestPath) && !File.Exists(SourceManifestPath))
            {
                Log.LogError("SourceManifestPath '{0}' does not exist; failing the build to prevent creating VSIX with unsynced manifest", SourceManifestPath);
                return false;
            }

            XmlDocument doc = new XmlDocument();
            doc.Load(ManifestPath);
            XmlNamespaceManager ns = new XmlNamespaceManager(doc.NameTable);
            ns.AddNamespace("x", ManifestNamespace);
            XmlElement root = doc.DocumentElement;
            if (root == null)
            {
                Log.LogError("Manifest '{0}' did not contain a document element", ManifestPath);
                return false;
            }

            if (!string.IsNullOrEmpty(SourceManifestPath))
            {
                XmlDocument sourceDoc = new XmlDocument();
                sourceDoc.Load(SourceManifestPath);
                SyncSection(doc, root, sourceDoc, "Installation");
                SyncSection(doc, root, sourceDoc, "Dependencies");
                SyncSection(doc, root, sourceDoc, "Prerequisites");
                Log.LogMessage(MessageImportance.High, "Synchronized manifest installation metadata from source manifest: {0}", SourceManifestPath);
            }

            // Ensure Assets element exists
            XmlElement assetsElement = EnsureSection(doc, root, "Assets");

            // Find or create Microsoft.VisualStudio.VsPackage asset
            XmlNode pkgAsset = doc.SelectSingleNode("//x:Asset[@Type='Microsoft.VisualStudio.VsPackage']", ns);
            if (pkgAsset == null)
            {
                pkgAsset = doc.CreateElement("Asset", ManifestNamespace);
                XmlElement pkgElement = (XmlElement)pkgAsset;
                pkgElement.SetAttribute("Type", "Microsoft.VisualStudio.VsPackage");
                pkgElement.SetAttribute("Path", PkgdefFileName);
                assetsElement.AppendChild(pkgAsset);
            }
            else
            {
                ((XmlElement)pkgAsset).SetAttribute("Path", PkgdefFileName);
            }

            doc.Save(ManifestPath);
            Log.LogMessage(MessageImportance.High, "Injected VsPackage asset into manifest: {0}", ManifestPath);
        }
        catch (Exception ex)
        {
            Log.LogError("Failed to inject VsPackage asset into manifest {0}: {1}", ManifestPath, ex.Message);
        }
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <!--
    PatchVsixForInProcPackage Task: Repacks the produced VSIX zip so VS treats it
    as a hybrid OOP + in-proc extension and can register the in-proc Tools > Options
    package after a standard VSIXInstaller / Marketplace install.
    
    The Microsoft.VisualStudio.Extensibility OOP build pipeline overwrites the
    detokenized extension.vsixmanifest with a synthesized one (Identity Version
    0.0.0.0, Community-only target). This task patches that manifest INSIDE the
    .vsix zip after CreateVsixContainer using the project's source.extension.vsixmanifest
    as the authority for Identity, Installation, Dependencies, and Prerequisites,
    keeps the OOP-only ExtensionType/DotnetTargetVersions, adds the
    Microsoft.VisualStudio.VsPackage asset, and copies the in-proc package payload
    (DLL, pkgdef, supporting assemblies) into the VSIX so VS can load it in proc.
    
    Parameters:
    - VsixPath: Full path to the produced .vsix archive.
    - SourceManifestPath: Full path to source.extension.vsixmanifest.
    - PackageDllPath: Full path to the in-proc package DLL.
    - PackagePkgdefPath: Full path to the generated package pkgdef.
    - SupportingAssemblies: Optional semicolon-separated list of supporting assemblies (e.g., Community.VisualStudio.Toolkit.dll) to copy into the VSIX.
  -->
  <UsingTask TaskName="PatchVsixForInProcPackage" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <VsixPath ParameterType="System.String" Required="true" />
      <SourceManifestPath ParameterType="System.String" Required="true" />
      <PackageDllPath ParameterType="System.String" Required="true" />
      <PackagePkgdefPath ParameterType="System.String" Required="true" />
      <SupportingAssemblies ParameterType="System.String" Required="false" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.IO.Compression" />
      <Using Namespace="System.Linq" />
      <Using Namespace="System.Text" />
      <Using Namespace="System.Xml" />
      <Code>
        <![CDATA[
        const string Ns = "http://schemas.microsoft.com/developer/vsx-schema/2011";

        try
        {
            if (!File.Exists(VsixPath))
            {
                Log.LogError("VSIX not found at {0}", VsixPath);
                return false;
            }
            if (!File.Exists(SourceManifestPath))
            {
                Log.LogError("Source manifest not found at {0}", SourceManifestPath);
                return false;
            }
            if (!File.Exists(PackageDllPath))
            {
                Log.LogError("In-proc package DLL not found at {0}", PackageDllPath);
                return false;
            }
            if (!File.Exists(PackagePkgdefPath))
            {
                Log.LogError("In-proc package pkgdef not found at {0}", PackagePkgdefPath);
                return false;
            }

            string workDir = Path.Combine(Path.GetDirectoryName(VsixPath), "_vsix_patch_" + Guid.NewGuid().ToString("N"));
            Directory.CreateDirectory(workDir);
            try
            {
                ZipFile.ExtractToDirectory(VsixPath, workDir);

                string manifestPath = Path.Combine(workDir, "extension.vsixmanifest");
                if (!File.Exists(manifestPath))
                {
                    Log.LogError("Produced VSIX is missing extension.vsixmanifest");
                    return false;
                }

                // Load both manifests
                XmlDocument synthDoc = new XmlDocument { PreserveWhitespace = false };
                synthDoc.Load(manifestPath);

                XmlDocument sourceDoc = new XmlDocument { PreserveWhitespace = false };
                sourceDoc.Load(SourceManifestPath);

                XmlElement synthRoot = synthDoc.DocumentElement;
                XmlElement sourceRoot = sourceDoc.DocumentElement;

                if (synthRoot == null || sourceRoot == null)
                {
                    Log.LogError("Manifest documents are missing root element");
                    return false;
                }

                // Start fresh from a copy of the source manifest so Identity, Installation,
                // Dependencies, Prerequisites and Metadata are authoritatively from source.
                XmlDocument outDoc = (XmlDocument)sourceDoc.CloneNode(true);
                XmlElement outRoot = outDoc.DocumentElement;

                // Preserve OOP-only Installation attributes from the synthesized manifest.
                // The synth Installation declares ExtensionType="VisualStudio.Extensibility"
                // and contains <DotnetTargetVersions>net8.0</DotnetTargetVersions>. We need
                // both to keep the OOP host loading the net8 extension; we also need the
                // VSSDK side to load the in-proc package, so ExtensionType is rewritten to
                // the hybrid form used by Microsoft.VisualStudio.Copilot.Testing.UI.
                XmlElement synthInstallation = synthRoot.ChildNodes
                    .OfType<XmlNode>()
                    .FirstOrDefault(n => n.NodeType == XmlNodeType.Element && n.LocalName == "Installation" && n.NamespaceURI == Ns) as XmlElement;
                XmlElement outInstallation = outRoot.ChildNodes
                    .OfType<XmlNode>()
                    .FirstOrDefault(n => n.NodeType == XmlNodeType.Element && n.LocalName == "Installation" && n.NamespaceURI == Ns) as XmlElement;

                if (outInstallation == null)
                {
                    Log.LogError("Source manifest is missing <Installation>");
                    return false;
                }

                outInstallation.SetAttribute("ExtensionType", "VSSDK+VisualStudio.Extensibility");

                if (synthInstallation != null)
                {
                    foreach (XmlNode synthChild in synthInstallation.ChildNodes)
                    {
                        if (synthChild.NodeType != XmlNodeType.Element) continue;
                        if (synthChild.LocalName == "DotnetTargetVersions" && synthChild.NamespaceURI == Ns)
                        {
                            XmlNode imported = outDoc.ImportNode(synthChild, true);
                            outInstallation.AppendChild(imported);
                        }
                    }
                }

                // Ensure Assets contains the VsPackage asset for the generated pkgdef.
                XmlElement outAssets = outRoot.ChildNodes
                    .OfType<XmlNode>()
                    .FirstOrDefault(n => n.NodeType == XmlNodeType.Element && n.LocalName == "Assets" && n.NamespaceURI == Ns) as XmlElement;
                if (outAssets == null)
                {
                    outAssets = outDoc.CreateElement("Assets", Ns);
                    outRoot.AppendChild(outAssets);
                }

                string pkgdefFileName = Path.GetFileName(PackagePkgdefPath);
                bool hasVsPackage = outAssets.ChildNodes
                    .OfType<XmlNode>()
                    .Any(n => n.NodeType == XmlNodeType.Element
                        && n.LocalName == "Asset"
                        && n.NamespaceURI == Ns
                        && ((XmlElement)n).GetAttribute("Type") == "Microsoft.VisualStudio.VsPackage");
                if (!hasVsPackage)
                {
                    XmlElement vsPackage = outDoc.CreateElement("Asset", Ns);
                    vsPackage.SetAttribute("Type", "Microsoft.VisualStudio.VsPackage");
                    vsPackage.SetAttribute("Path", pkgdefFileName);
                    outAssets.AppendChild(vsPackage);
                }

                // Save patched extension.vsixmanifest
                using (var writer = new StreamWriter(manifestPath, false, new System.Text.UTF8Encoding(true)))
                {
                    outDoc.Save(writer);
                }

                // Patch setup-engine manifest.json as well. VSIXInstaller validates this file
                // before deployment, and stale values can fail installation even when
                // extension.vsixmanifest has already been corrected.
                string setupManifestPath = Path.Combine(workDir, "manifest.json");
                if (File.Exists(setupManifestPath))
                {
                    string setupManifestText = File.ReadAllText(setupManifestPath, Encoding.UTF8);
                    XmlElement sourceMetadata = sourceRoot.ChildNodes
                        .OfType<XmlNode>()
                        .FirstOrDefault(n => n.NodeType == XmlNodeType.Element && n.LocalName == "Metadata" && n.NamespaceURI == Ns) as XmlElement;
                    XmlElement sourceIdentity = sourceMetadata == null
                        ? null
                        : sourceMetadata.ChildNodes
                            .OfType<XmlNode>()
                            .FirstOrDefault(n => n.NodeType == XmlNodeType.Element && n.LocalName == "Identity" && n.NamespaceURI == Ns) as XmlElement;
                    string sourceVersion = sourceIdentity == null ? string.Empty : sourceIdentity.GetAttribute("Version");

                    if (!string.IsNullOrEmpty(sourceVersion))
                    {
                        setupManifestText = System.Text.RegularExpressions.Regex.Replace(
                            setupManifestText,
                            "\"version\"\\s*:\\s*\"[^\"]*\"",
                            "\"version\":\"" + sourceVersion + "\"");
                    }

                    // Installer validation for user-scoped VSIX install expects the Extensions
                    // path family, not VSExtensions.
                    setupManifestText = setupManifestText.Replace(
                        "\\\\Common7\\\\IDE\\\\VSExtensions\\\\",
                        "\\\\Common7\\\\IDE\\\\Extensions\\\\");

                    File.WriteAllText(setupManifestPath, setupManifestText, new UTF8Encoding(true));
                    Log.LogMessage(MessageImportance.High, "Patched setup manifest.json inside VSIX.");
                }

                // Keep catalog.json consistent with extension.vsixmanifest / manifest.json.
                // Setup Engine enforces cross-manifest consistency and rejects mismatched versions.
                string catalogPath = Path.Combine(workDir, "catalog.json");
                if (File.Exists(catalogPath))
                {
                    string catalogText = File.ReadAllText(catalogPath, Encoding.UTF8);
                    XmlElement sourceMetadata = sourceRoot.ChildNodes
                        .OfType<XmlNode>()
                        .FirstOrDefault(n => n.NodeType == XmlNodeType.Element && n.LocalName == "Metadata" && n.NamespaceURI == Ns) as XmlElement;
                    XmlElement sourceIdentity = sourceMetadata == null
                        ? null
                        : sourceMetadata.ChildNodes
                            .OfType<XmlNode>()
                            .FirstOrDefault(n => n.NodeType == XmlNodeType.Element && n.LocalName == "Identity" && n.NamespaceURI == Ns) as XmlElement;
                    string sourceVersion = sourceIdentity == null ? string.Empty : sourceIdentity.GetAttribute("Version");

                    if (!string.IsNullOrEmpty(sourceVersion))
                    {
                        catalogText = catalogText.Replace("0.0.0.0", sourceVersion);
                    }

                    catalogText = catalogText.Replace(
                        "\\\\Common7\\\\IDE\\\\VSExtensions\\\\",
                        "\\\\Common7\\\\IDE\\\\Extensions\\\\");

                    File.WriteAllText(catalogPath, catalogText, new UTF8Encoding(true));
                    Log.LogMessage(MessageImportance.High, "Patched catalog.json inside VSIX.");
                }

                // Copy in-proc package payload into the VSIX root
                string destDll = Path.Combine(workDir, Path.GetFileName(PackageDllPath));
                File.Copy(PackageDllPath, destDll, overwrite: true);

                string destPkgdef = Path.Combine(workDir, pkgdefFileName);
                File.Copy(PackagePkgdefPath, destPkgdef, overwrite: true);

                if (!string.IsNullOrEmpty(SupportingAssemblies))
                {
                    foreach (string sa in SupportingAssemblies.Split(new[] { ';' }, StringSplitOptions.RemoveEmptyEntries))
                    {
                        string trimmed = sa.Trim();
                        if (string.IsNullOrEmpty(trimmed) || !File.Exists(trimmed)) continue;
                        string destSa = Path.Combine(workDir, Path.GetFileName(trimmed));
                        File.Copy(trimmed, destSa, overwrite: true);
                    }
                }

                // Patch [Content_Types].xml to register .pkgdef
                string contentTypesPath = Path.Combine(workDir, "[Content_Types].xml");
                if (File.Exists(contentTypesPath))
                {
                    XmlDocument ctDoc = new XmlDocument { PreserveWhitespace = false };
                    ctDoc.Load(contentTypesPath);
                    string ctNs = "http://schemas.openxmlformats.org/package/2006/content-types";
                    bool hasPkgdef = ctDoc.DocumentElement.ChildNodes
                        .OfType<XmlNode>()
                        .Any(n => n.NodeType == XmlNodeType.Element && n.LocalName == "Default"
                            && ((XmlElement)n).GetAttribute("Extension").Equals("pkgdef", StringComparison.OrdinalIgnoreCase));
                    if (!hasPkgdef)
                    {
                        XmlElement def = ctDoc.CreateElement("Default", ctNs);
                        def.SetAttribute("Extension", "pkgdef");
                        def.SetAttribute("ContentType", "text/plain");
                        ctDoc.DocumentElement.AppendChild(def);
                        using (var writer = new StreamWriter(contentTypesPath, false, new System.Text.UTF8Encoding(true)))
                        {
                            ctDoc.Save(writer);
                        }
                    }
                }

                // Repack VSIX
                string repackPath = VsixPath + ".tmp";
                if (File.Exists(repackPath)) File.Delete(repackPath);
                ZipFile.CreateFromDirectory(workDir, repackPath, CompressionLevel.Optimal, includeBaseDirectory: false);
                File.Delete(VsixPath);
                File.Move(repackPath, VsixPath);

                Log.LogMessage(MessageImportance.High,
                    "Patched VSIX for in-proc package: manifest updated, payload + pkgdef + supporting assemblies injected ({0})",
                    VsixPath);
            }
            finally
            {
                try { Directory.Delete(workDir, recursive: true); } catch { }
            }
        }
        catch (Exception ex)
        {
            Log.LogError("PatchVsixForInProcPackage failed: {0}", ex.ToString());
            return false;
        }
        return true;
        ]]>
      </Code>
    </Task>
  </UsingTask>
</Project>

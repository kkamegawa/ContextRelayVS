<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <NoWarn>NU1603;NU1605;VSEXTPREVIEW_OUTPUTWINDOW</NoWarn>
    <RootNamespace>ContextRelay.VSExtension</RootNamespace>
    <AssemblyName>ContextRelay.VSExtension</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/kkamegawa/ContextRelayVS</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <!-- Required by VSEXT0008: enables VSSDK+VisualStudio.Extensibility hybrid in-process hosting -->
    <VssdkcompatibleExtension>true</VssdkcompatibleExtension>
    <InProcPackageTargetFramework>net48</InProcPackageTargetFramework>
    <VsixExtensionId>ContextRelayVS.kkamegawa.d0dd4dd5-7d88-4b80-8d4d-9dd18fa4cf11</VsixExtensionId>
    <InProcPackageOutputDir>$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '..', 'ContextRelay.VSExtension.Package', 'bin', '$(Configuration)', '$(InProcPackageTargetFramework)'))</InProcPackageOutputDir>
    <InProcToolkitAssemblyPath>$([System.IO.Path]::Combine('$(InProcPackageOutputDir)', 'Community.VisualStudio.Toolkit.dll'))</InProcToolkitAssemblyPath>
  </PropertyGroup>

  <UsingTask TaskName="PatchPkgdefFile" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
	<ParameterGroup>
	  <PkgdefPath Required="true" />
	</ParameterGroup>
	<Task>
	  <Code Type="Fragment" Language="cs">
		<![CDATA[
		try {
		  if (!System.IO.File.Exists(PkgdefPath)) {
			Log.LogError("pkgdef not found at: {0}", PkgdefPath);
			return false;
		  }

		  var content = System.IO.File.ReadAllText(PkgdefPath, System.Text.Encoding.UTF8);
		  
		  // Keep the legacy options page visible
		  content = System.Text.RegularExpressions.Regex.Replace(
			content,
			"\"IsInUnifiedSettings\"=dword:00000001",
			"\"IsInUnifiedSettings\"=dword:00000000"
		  );
		  
		  // Replace numeric resource references with literal display names
		  content = System.Text.RegularExpressions.Regex.Replace(
			content,
			"(?m)^(\\[.*ToolsOptionsPages\\\\ContextRelay\\]\\s*\\r?\\n)@=\"#\\d+\"",
			"$1@=\"ContextRelay\"",
			System.Text.RegularExpressions.RegexOptions.Multiline
		  );
		  
		  content = System.Text.RegularExpressions.Regex.Replace(
			content,
			"(?m)^(\\[.*ToolsOptionsPages\\\\ContextRelay\\\\General\\]\\s*\\r?\\n)@=\"#\\d+\"",
			"$1@=\"General\"",
			System.Text.RegularExpressions.RegexOptions.Multiline
		  );
		  
		  System.IO.File.WriteAllText(PkgdefPath, content, System.Text.Encoding.UTF8);
		  Log.LogMessage("Patched pkgdef: {0}", PkgdefPath);
		  return true;
		}
		catch (System.Exception ex) {
		  Log.LogError("Error patching pkgdef: {0}", ex.Message);
		  return false;
		}
		]]>
	  </Code>
	</Task>
  </UsingTask>

  <UsingTask TaskName="InjectVsPackageAsset" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
	<ParameterGroup>
	  <ManifestPath Required="true" />
	  <SourceManifestPath Required="false" />
	</ParameterGroup>
	<Task>
	  <Code Type="Fragment" Language="cs">
		<![CDATA[
		try {
		  if (!System.IO.File.Exists(ManifestPath)) {
			Log.LogError("Manifest not found at: {0}", ManifestPath);
			return false;
		  }

		  var xml = new System.Xml.XmlDocument();
		  xml.Load(ManifestPath);
		  
		  var ns = new System.Xml.XmlNamespaceManager(xml.NameTable);
		  ns.AddNamespace("pm", "http://schemas.microsoft.com/developer/vsx-schema/2011");
		  
		  // Sync sections from source manifest if provided
		  if (!string.IsNullOrWhiteSpace(SourceManifestPath) && System.IO.File.Exists(SourceManifestPath)) {
			var sourceXml = new System.Xml.XmlDocument();
			sourceXml.Load(SourceManifestPath);
			var sourceNs = new System.Xml.XmlNamespaceManager(sourceXml.NameTable);
			sourceNs.AddNamespace("pm", "http://schemas.microsoft.com/developer/vsx-schema/2011");
			
			var sections = new[] { "Metadata", "Installation", "Dependencies", "Prerequisites" };
			foreach (var section in sections) {
			  var existingNode = xml.DocumentElement.SelectSingleNode("pm:" + section, ns);
			  if (existingNode != null) {
				xml.DocumentElement.RemoveChild(existingNode);
			  }
			  
			  var sourceNode = sourceXml.SelectSingleNode("//pm:" + section, sourceNs);
			  if (sourceNode != null) {
				var importedNode = xml.ImportNode(sourceNode, true);
				xml.DocumentElement.AppendChild(importedNode);
			  }
			}
			Log.LogMessage("Synchronized manifest metadata and installation targets from source manifest");
		  }
		  
		  // Ensure Assets element exists
		  var assetsNode = xml.SelectSingleNode("//pm:Assets", ns) as System.Xml.XmlElement;
		  if (assetsNode == null) {
			assetsNode = xml.CreateElement("Assets", "http://schemas.microsoft.com/developer/vsx-schema/2011");
			xml.DocumentElement.AppendChild(assetsNode);
			Log.LogMessage("Created Assets element");
		  }
		  
		  // Inject or update VsPackage asset
		  var vsPackageAsset = xml.SelectSingleNode("//pm:Asset[@Type='Microsoft.VisualStudio.VsPackage']", ns) as System.Xml.XmlElement;
		  if (vsPackageAsset == null) {
			var assetNode = xml.CreateElement("Asset", "http://schemas.microsoft.com/developer/vsx-schema/2011");
			assetNode.SetAttribute("Type", "Microsoft.VisualStudio.VsPackage");
			assetNode.SetAttribute("Path", "ContextRelay.VSExtension.Package.pkgdef");
			assetsNode.AppendChild(assetNode);
			Log.LogMessage("Injected VsPackage asset into manifest: {0}", ManifestPath);
		  }
		  else {
			vsPackageAsset.SetAttribute("Path", "ContextRelay.VSExtension.Package.pkgdef");
			Log.LogMessage("Normalized VsPackage asset in manifest");
		  }
		  
		  xml.Save(ManifestPath);
		  return true;
		}
		catch (System.Exception ex) {
		  Log.LogError("Error injecting VsPackage asset: {0}", ex.Message);
		  return false;
		}
		]]>
	  </Code>
	</Task>
  </UsingTask>

  <ItemGroup>
    <None Remove="icon.png" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\ContextRelay.Core\ContextRelay.Core.csproj" />
    <ProjectReference Include="..\ContextRelay.VSExtension.Package\ContextRelay.VSExtension.Package.csproj">
      <Name>ContextRelay.VSExtension.Package</Name>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <IncludeOutputGroupsInVSIX>BuiltProjectOutputGroup;PkgdefProjectOutputGroup</IncludeOutputGroupsInVSIX>
      <IncludeOutputGroupsInVSIXLocalOnly>DebugSymbolsProjectOutputGroup</IncludeOutputGroupsInVSIXLocalOnly>
    </ProjectReference>
  </ItemGroup>
  <ItemGroup>
    <Content Include="icon.png">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="LICENSE.txt">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Include="source.extension.vsixmanifest">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <None Include="..\..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.Shell.15.0" Version="17.14.40264" PrivateAssets="all" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.VisualStudio.Extensibility.Sdk" Version="17.14.40608" PrivateAssets="all" />
    <PackageReference Include="Microsoft.VisualStudio.Extensibility" Version="17.14.2098" />
    <PackageReference Include="Microsoft.VisualStudio.Extensibility.Build" Version="17.14.40608" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup Condition="Exists('$(InProcToolkitAssemblyPath)')">
    <Content Include="$(InProcToolkitAssemblyPath)">
      <IncludeInVSIX>true</IncludeInVSIX>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>Community.VisualStudio.Toolkit.dll</Link>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <None Update="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
    <Page Remove="ToolWindows\ContextRelayWindowContent.xaml" />
    <EmbeddedResource Include="ToolWindows\ContextRelayWindowContent.xaml">
      <LogicalName>ContextRelay.VSExtension.ToolWindows.ContextRelayWindowContent.xaml</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!--
    Extensibility.Build.targets (OOP mode) generates a minimal extension.vsixmanifest that omits custom Assets.
    We copy our source.extension.vsixmanifest to the intermediate directory before DetokenizeVsixManifestFile
    runs to ensure the Assets section is preserved in the final manifest.
  -->
  <Target Name="CopyVsixManifestToIntermediate" BeforeTargets="DetokenizeVsixManifestFile">
    <MakeDir Directories="$(IntermediateOutputPath)" />
    <Copy SourceFiles="$(MSBuildProjectDirectory)\source.extension.vsixmanifest" DestinationFiles="$(IntermediateOutputPath)extension.vsixmanifest" />
  </Target>

  <!--
    After VSIX manifest is tokenized, inject the VsPackage asset if it's missing.
    This PowerShell script modifies the final extension.vsixmanifest to ensure the in-proc package is registered.
  -->
  <Target Name="EnsureVsPackageAssetInManifest" AfterTargets="DetokenizeVsixManifestFile" BeforeTargets="CreateVsixContainer">
    <InjectVsPackageAsset ManifestPath="$(IntermediateOutputPath)extension.vsixmanifest" SourceManifestPath="$(MSBuildProjectDirectory)\source.extension.vsixmanifest" />
  </Target>

  <!--
    Patch the pkgdef collected from the package project just before VSIX packaging.
    The PkgdefProjectOutputGroup invocation regenerates the pkgdef file, so we must
    patch it here (after all pkgdef generation) to keep the legacy options page
    visible and ensure display names are correct in the final VSIX.
  -->
  <Target Name="PatchPackagePkgdefOptionsRegistrationBeforeVsix" BeforeTargets="CreateVsixContainer" AfterTargets="GetVsixSourceItems">
    <PropertyGroup>
      <PackagePkgdefPath>$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '..', 'ContextRelay.VSExtension.Package', 'obj', '$(Configuration)', '$(InProcPackageTargetFramework)', 'ContextRelay.VSExtension.Package.pkgdef'))</PackagePkgdefPath>
      <LatestPackagePkgdefPath>$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '..', 'ContextRelay.VSExtension.Package', 'obj', '$(Configuration)', '$(InProcPackageTargetFramework)', 'ContextRelay.VSExtension.Package.latest.pkgdef'))</LatestPackagePkgdefPath>
    </PropertyGroup>
    <PatchPkgdefFile PkgdefPath="$(PackagePkgdefPath)" Condition="Exists('$(PackagePkgdefPath)')" />
    <PatchPkgdefFile PkgdefPath="$(LatestPackagePkgdefPath)" Condition="Exists('$(LatestPackagePkgdefPath)')" />
  </Target>

  <!--
    After F5 debug deployment, the OOP host deploys to VSExtensions which is NOT in the pkgdef
    search path. We copy the pkgdef and DLL to the Extensions folder so VS can register the
    in-proc package (ContextRelayOptionsPackage) and show Tools > Options > ContextRelay.
    Also touch extensions.configurationchanged to force pkgdef cache invalidation.
    
    Run during Debug builds and whenever DeployExtension is true, to support both F5 debugging
    and VSIX deployment scenarios.
  -->
  <Target Name="DeployInProcPackageToExtensions" AfterTargets="Build" Condition="'$(Configuration)' == 'Debug' Or '$(DeployExtension)' == 'true'">
    <PropertyGroup>
      <_VsExpSuffix Condition="'$(_VsExpSuffix)' == ''">Exp</_VsExpSuffix>
      <_VsLocalAppData>$(LocalAppData)\Microsoft\VisualStudio</_VsLocalAppData>
      <_PkgdefSrc>$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '..', 'ContextRelay.VSExtension.Package', 'obj', '$(Configuration)', '$(InProcPackageTargetFramework)', 'ContextRelay.VSExtension.Package.pkgdef'))</_PkgdefSrc>
      <_DllSrc>$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '..', 'ContextRelay.VSExtension.Package', 'bin', '$(Configuration)', '$(InProcPackageTargetFramework)', 'ContextRelay.VSExtension.Package.dll'))</_DllSrc>
      <_ToolkitDllSrc>$(InProcToolkitAssemblyPath)</_ToolkitDllSrc>
    </PropertyGroup>
    <Exec Command="powershell -Command Set-ExecutionPolicy -ExecutionPolicy Bypass -Scope Process -Force; &amp; '$(MSBuildThisFileDirectory)..\..\build\RemoveDuplicateExperimentalExtensions.ps1' -VsLocalAppData '$(_VsLocalAppData)' -RootSuffix '$(_VsExpSuffix)' -ExtensionId '$(VsixExtensionId)'" />
    <Exec Command="powershell -Command Set-ExecutionPolicy -ExecutionPolicy Bypass -Scope Process -Force; &amp; '$(MSBuildThisFileDirectory)..\..\build\DeployInProcPackage.ps1' -PkgdefPath '$(_PkgdefSrc)' -DllPath '$(_DllSrc)' -VsLocalAppData '$(_VsLocalAppData)' -RootSuffix '$(_VsExpSuffix)' -SupportingAssemblies '$(_ToolkitDllSrc)' -ExtensionId '$(VsixExtensionId)'" />
  </Target>
</Project>

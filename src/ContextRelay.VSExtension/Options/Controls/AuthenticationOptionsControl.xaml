<UserControl x:Class="ContextRelay.VSExtension.Options.Controls.AuthenticationOptionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="460" d:DesignHeight="280">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12">
            <TextBlock x:Name="PageTitleText" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" />

            <!-- Client ID -->
            <TextBlock x:Name="ClientIdLabelText" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock x:Name="ClientIdDescriptionText" TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,4" />
            <TextBox x:Name="ClientIdTextBox" Padding="4,3" />

            <Separator Margin="0,12" />

            <!-- Tenant ID -->
            <TextBlock x:Name="TenantIdLabelText" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock x:Name="TenantIdDescriptionText" TextWrapping="Wrap" Opacity="0.7" Margin="0,0,0,4" />
            <TextBox x:Name="TenantIdTextBox" Padding="4,3" />
        </StackPanel>
    </ScrollViewer>
</UserControl>

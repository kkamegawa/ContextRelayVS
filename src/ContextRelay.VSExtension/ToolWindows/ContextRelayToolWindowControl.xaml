<UserControl x:Class="ContextRelay.VSExtension.ToolWindows.ContextRelayToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <Button Margin="0,0,8,8" Padding="12,4" Content="Generate handoff" Click="GenerateHandoffButton_Click" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="Copy prompt" Click="CopyPromptButton_Click" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="Open handoff" Click="OpenHandoffButton_Click" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="Open Copilot" Click="OpenCopilotButton_Click" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="Clear chat" Click="ClearChatButton_Click" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="Clear snippets" Click="ClearSnippetsButton_Click" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="Clear cache" Click="ClearCacheButton_Click" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="Settings" Click="SettingsButton_Click" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="Debug log" Click="DebugLogButton_Click" />
        </WrapPanel>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchTextBox"
                     Grid.Column="0"
                     Margin="0,0,8,0"
                     Padding="8,6"
                     Text="{Binding QueryText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Use /mail /teams /sharepoint /onedrive /all /ask /clear"
                     KeyDown="SearchTextBox_KeyDown" />
            <Button Grid.Column="1" Padding="16,6" Content="Search" Click="SearchButton_Click" IsEnabled="{Binding IsNotBusy}" />
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="{Binding HelpText}" TextWrapping="Wrap" Opacity="0.8" />
            <TextBlock Margin="0,4,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap" FontWeight="SemiBold" />
            <TextBlock Margin="0,2,0,0" Text="{Binding SignedInUserText}" TextWrapping="Wrap" Opacity="0.8" />
        </StackPanel>

        <GroupBox Grid.Row="3" Header="Search results" Margin="0,0,0,8">
            <ListBox ItemsSource="{Binding SearchResults}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" BorderThickness="0,0,0,1" BorderBrush="#33000000">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0">
                                    <TextBlock DockPanel.Dock="Left" FontWeight="Bold" Text="{Binding Title}" TextWrapping="Wrap" />
                                    <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" Text="{Binding Source}" Opacity="0.75" />
                                </DockPanel>
                                <TextBlock Grid.Row="1" Margin="0,4,0,0" Text="{Binding Snippet}" TextWrapping="Wrap" />
                                <StackPanel Grid.Row="2" Margin="0,6,0,0" Orientation="Horizontal">
                                    <TextBlock Margin="0,0,12,0" Text="{Binding Timestamp}" Opacity="0.7" />
                                    <Button Margin="0,0,8,0" Padding="8,2" Content="Pin" Tag="{Binding}" Click="PinResultButton_Click" />
                                    <Button Padding="8,2" Content="Open" Tag="{Binding}" Click="OpenResultButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Pinned snippets" Margin="0,0,8,0">
                <ListBox ItemsSource="{Binding Snippets}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" BorderThickness="0,0,0,1" BorderBrush="#33000000">
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" Text="{Binding Name}" />
                                    <TextBlock Margin="0,2,0,0" Text="{Binding Snippet}" TextWrapping="Wrap" />
                                    <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                        <TextBlock Margin="0,0,12,0" Text="{Binding Source}" Opacity="0.75" />
                                        <Button Margin="0,0,8,0" Padding="8,2" Content="Open" Tag="{Binding}" Click="OpenSnippetButton_Click" />
                                        <Button Padding="8,2" Content="Delete" Tag="{Binding}" Click="DeleteSnippetButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Shared chat history">
                <ListBox ItemsSource="{Binding ChatHistory}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" BorderThickness="0,0,0,1" BorderBrush="#33000000">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" FontWeight="Bold" Text="{Binding Role}" />
                                        <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" Text="{Binding Timestamp}" Opacity="0.7" />
                                    </DockPanel>
                                    <TextBlock Margin="0,4,0,0" Text="{Binding Text}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>

<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:vstheme="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0">
    <DataTemplate.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <Style x:Key="SurfaceBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vstheme:EnvironmentColors.PanelBorderBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vstheme:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vstheme:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="Opacity" Value="0.78" />
        </Style>
    </DataTemplate.Resources>

    <Grid Margin="12" Background="{DynamicResource {x:Static vstheme:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SurfaceBorderStyle}" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding WindowTitleText}" Foreground="{DynamicResource {x:Static vstheme:EnvironmentColors.ToolWindowTextBrushKey}}" />
                        <Button Margin="10,0,6,0" Padding="8,2" Content="{Binding UseEnglishButtonText}" Command="{Binding UseEnglishCommand}" IsEnabled="{Binding IsNotBusy}" />
                        <Button Padding="8,2" Content="{Binding UseJapaneseButtonText}" Command="{Binding UseJapaneseCommand}" IsEnabled="{Binding IsNotBusy}" />
                    </StackPanel>
                    <TextBlock Margin="0,3,0,0" Text="{Binding SignedInUserText}" Style="{StaticResource MutedTextStyle}" />
                    <TextBlock Margin="0,3,0,0" Text="{Binding StatusMessage}" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource {x:Static vstheme:EnvironmentColors.ToolWindowTextBrushKey}}" />
                    <TextBlock Margin="0,3,0,0" Text="{Binding HelpText}" TextWrapping="Wrap" Style="{StaticResource MutedTextStyle}" />
                </StackPanel>

                <WrapPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                    <Button Margin="0,0,6,6" Padding="10,4" Content="{Binding GenerateHandoffButtonText}" Command="{Binding GenerateHandoffCommand}" IsEnabled="{Binding IsNotBusy}" />
                    <Button Margin="0,0,6,6" Padding="10,4" Content="{Binding CopyPromptButtonText}" Command="{Binding CopyPromptCommand}" IsEnabled="{Binding IsNotBusy}" />
                    <Button Margin="0,0,6,6" Padding="10,4" Content="{Binding OpenHandoffButtonText}" Command="{Binding OpenHandoffCommand}" IsEnabled="{Binding IsNotBusy}" />
                    <Button Margin="0,0,6,6" Padding="10,4" Content="{Binding OpenCopilotButtonText}" Command="{Binding OpenCopilotCommand}" IsEnabled="{Binding IsNotBusy}" />
                    <Button Margin="0,0,6,6" Padding="10,4" Content="{Binding SettingsButtonText}" Command="{Binding OpenSettingsCommand}" IsEnabled="{Binding IsNotBusy}" />
                    <Button Margin="0,0,6,6" Padding="10,4" Content="{Binding DebugLogButtonText}" Command="{Binding ShowDebugLogCommand}" />
                    <Button Margin="0,0,6,6" Padding="10,4" Content="{Binding ClearChatButtonText}" Command="{Binding ClearChatCommand}" IsEnabled="{Binding IsNotBusy}" />
                    <Button Margin="0,0,6,6" Padding="10,4" Content="{Binding ClearSnippetsButtonText}" Command="{Binding ClearSnippetsCommand}" IsEnabled="{Binding IsNotBusy}" />
                    <Button Margin="0,0,0,6" Padding="10,4" Content="{Binding ClearCacheButtonText}" Command="{Binding ClearCacheCommand}" IsEnabled="{Binding IsNotBusy}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SurfaceBorderStyle}" Margin="0,0,10,0">
                <ListBox ItemsSource="{Binding ChatHistory}" BorderThickness="0" Background="{DynamicResource {x:Static vstheme:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="8,8,8,0"
                                    Padding="10"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource {x:Static vstheme:EnvironmentColors.PanelBorderBrushKey}}"
                                    Background="{DynamicResource {x:Static vstheme:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding Role}" Foreground="{DynamicResource {x:Static vstheme:EnvironmentColors.ToolWindowTextBrushKey}}" />
                                        <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" Text="{Binding Timestamp}" Style="{StaticResource MutedTextStyle}" />
                                    </DockPanel>
                                    <TextBlock Margin="0,6,0,0" Text="{Binding Text}" TextWrapping="Wrap" Foreground="{DynamicResource {x:Static vstheme:EnvironmentColors.ToolWindowTextBrushKey}}" />
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Style="{StaticResource MutedTextStyle}"
                                               Visibility="{Binding HasContextLabels, Converter={StaticResource BoolToVisConverter}}">
                                        <Run Text="{Binding ContextLabelsPrefixText}" />
                                        <Run Text="{Binding ContextLabelsJoinedDisplay}" />
                                    </TextBlock>
                                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal"
                                                Visibility="{Binding IsActionableAssistant, Converter={StaticResource BoolToVisConverter}}">
                                        <Button Margin="0,0,8,0" Padding="8,2" Content="{Binding CopyAssistantButtonText}" Command="{Binding CopyAssistantCommand}" />
                                        <Button Margin="0,0,8,0" Padding="8,2" Content="{Binding AppendAssistantButtonText}" Command="{Binding AppendAssistantCommand}" />
                                        <Button Padding="8,2" Content="{Binding ReplaceAssistantButtonText}" Command="{Binding ReplaceAssistantCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SurfaceBorderStyle}">
                <TabControl Background="{DynamicResource {x:Static vstheme:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static vstheme:EnvironmentColors.PanelBorderBrushKey}}">
                    <TabItem Header="{Binding SearchResultsHeaderText}">
                        <ListBox ItemsSource="{Binding SearchResults}" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource {x:Static vstheme:EnvironmentColors.PanelBorderBrushKey}}">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{Binding PinButtonText}" Command="{Binding PinCommand}" />
                                                <MenuItem Header="{Binding CopyMenuText}" Command="{Binding CopyCommand}" />
                                                <MenuItem Header="{Binding AppendToHandoffMenuText}" Command="{Binding AppendToHandoffCommand}" />
                                                <Separator />
                                                <MenuItem Header="{Binding OpenInBrowserMenuText}" Command="{Binding OpenCommand}" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <DockPanel Grid.Row="0">
                                                <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                                                <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" Text="{Binding Source}" Style="{StaticResource MutedTextStyle}" />
                                            </DockPanel>
                                            <TextBlock Grid.Row="1" Margin="0,4,0,0" Text="{Binding Snippet}" TextWrapping="Wrap" />
                                            <StackPanel Grid.Row="2" Margin="0,6,0,0" Orientation="Horizontal">
                                                <TextBlock Margin="0,0,12,0" Text="{Binding Timestamp}" Style="{StaticResource MutedTextStyle}" />
                                                <Button Margin="0,0,8,0" Padding="8,2" Content="{Binding PinButtonText}" Command="{Binding PinCommand}" />
                                                <Button Padding="8,2" Content="{Binding OpenButtonText}" Command="{Binding OpenCommand}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>

                    <TabItem Header="{Binding SnippetsHeaderText}">
                        <ListBox ItemsSource="{Binding Snippets}" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource {x:Static vstheme:EnvironmentColors.PanelBorderBrushKey}}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                            <TextBlock Margin="0,2,0,0" Text="{Binding Snippet}" TextWrapping="Wrap" />
                                            <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                                <TextBlock Margin="0,0,12,0" Text="{Binding Source}" Style="{StaticResource MutedTextStyle}" />
                                                <Button Margin="0,0,8,0" Padding="8,2" Content="{Binding OpenButtonText}" Command="{Binding OpenCommand}" />
                                                <Button Padding="8,2" Content="{Binding DeleteButtonText}" Command="{Binding DeleteCommand}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                    Margin="0,0,0,6"
                    Style="{StaticResource SurfaceBorderStyle}"
                    Visibility="{Binding IsCommandPopupOpen, Converter={StaticResource BoolToVisConverter}}">
                <StackPanel>
                    <TextBlock Margin="8,6,8,4" FontWeight="SemiBold" Text="{Binding CommandPopupHeaderText}" Style="{StaticResource MutedTextStyle}" />
                    <ListBox MaxHeight="220" BorderThickness="0"
                             ItemsSource="{Binding CommandSuggestions}"
                             SelectedItem="{Binding SelectedCommandSuggestion, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8,4">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                    <TextBlock Margin="0,2,0,0" Text="{Binding Description}" TextWrapping="Wrap" Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <TextBox Grid.Row="1" Grid.Column="0"
                     Margin="0,0,8,0"
                     Padding="10,8"
                     Text="{Binding QueryText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="{Binding SearchToolTipText}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                    <KeyBinding Key="Down" Command="{Binding MoveSelectionDownCommand}" />
                    <KeyBinding Key="Up" Command="{Binding MoveSelectionUpCommand}" />
                    <KeyBinding Key="Tab" Command="{Binding ApplyCommandSelectionCommand}" />
                    <KeyBinding Key="Escape" Command="{Binding CloseCommandPopupCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <Button Grid.Row="1" Grid.Column="1" Padding="16,8" Content="{Binding SearchButtonText}" Command="{Binding SearchCommand}" IsEnabled="{Binding IsNotBusy}" />
        </Grid>
    </Grid>
</DataTemplate>

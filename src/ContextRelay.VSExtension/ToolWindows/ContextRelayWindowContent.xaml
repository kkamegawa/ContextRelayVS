<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DataTemplate.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
    </DataTemplate.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <Button Margin="0,0,8,8" Padding="12,4" Content="{Binding GenerateHandoffButtonText}" Command="{Binding GenerateHandoffCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="{Binding CopyPromptButtonText}" Command="{Binding CopyPromptCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="{Binding OpenHandoffButtonText}" Command="{Binding OpenHandoffCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="{Binding OpenCopilotButtonText}" Command="{Binding OpenCopilotCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="{Binding ClearChatButtonText}" Command="{Binding ClearChatCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="{Binding ClearSnippetsButtonText}" Command="{Binding ClearSnippetsCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="{Binding ClearCacheButtonText}" Command="{Binding ClearCacheCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="{Binding SettingsButtonText}" Command="{Binding OpenSettingsCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Margin="0,0,8,8" Padding="12,4" Content="{Binding DebugLogButtonText}" Command="{Binding ShowDebugLogCommand}" />
        </WrapPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Margin="0,0,8,0" Padding="8,6"
                         Text="{Binding QueryText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="{Binding SearchToolTipText}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                        <KeyBinding Key="Down" Command="{Binding MoveSelectionDownCommand}" />
                        <KeyBinding Key="Up" Command="{Binding MoveSelectionUpCommand}" />
                        <KeyBinding Key="Tab" Command="{Binding ApplyCommandSelectionCommand}" />
                        <KeyBinding Key="Escape" Command="{Binding CloseCommandPopupCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="1" Padding="16,6" Content="{Binding SearchButtonText}" Command="{Binding SearchCommand}" IsEnabled="{Binding IsNotBusy}" />
            </Grid>

            <Border Margin="0,4,0,0"
                    Padding="0"
                    Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1"
                    Visibility="{Binding IsCommandPopupOpen, Converter={StaticResource BoolToVisConverter}}">
                <StackPanel>
                    <TextBlock Margin="8,6,8,4" FontWeight="SemiBold" Opacity="0.8" Text="{Binding CommandPopupHeaderText}" />
                    <ListBox MaxHeight="220" BorderThickness="0"
                             ItemsSource="{Binding CommandSuggestions}"
                             SelectedItem="{Binding SelectedCommandSuggestion, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8,4">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                    <TextBlock Margin="0,2,0,0" Opacity="0.8" Text="{Binding Description}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="{Binding HelpText}" TextWrapping="Wrap" Opacity="0.8" />
            <TextBlock Margin="0,4,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap" FontWeight="SemiBold" />
            <TextBlock Margin="0,2,0,0" Text="{Binding SignedInUserText}" TextWrapping="Wrap" Opacity="0.8" />
        </StackPanel>

        <GroupBox Grid.Row="3" Header="{Binding SearchResultsHeaderText}" Margin="0,0,0,8">
            <ListBox ItemsSource="{Binding SearchResults}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{Binding PinButtonText}" Command="{Binding PinCommand}" />
                                    <MenuItem Header="{Binding CopyMenuText}" Command="{Binding CopyCommand}" />
                                    <MenuItem Header="{Binding AppendToHandoffMenuText}" Command="{Binding AppendToHandoffCommand}" />
                                    <Separator />
                                    <MenuItem Header="{Binding OpenInBrowserMenuText}" Command="{Binding OpenCommand}" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0">
                                    <TextBlock DockPanel.Dock="Left" FontWeight="Bold" Text="{Binding Title}" TextWrapping="Wrap" />
                                    <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" Text="{Binding Source}" Opacity="0.75" />
                                </DockPanel>
                                <TextBlock Grid.Row="1" Margin="0,4,0,0" Text="{Binding Snippet}" TextWrapping="Wrap" />
                                <StackPanel Grid.Row="2" Margin="0,6,0,0" Orientation="Horizontal">
                                    <TextBlock Margin="0,0,12,0" Text="{Binding Timestamp}" Opacity="0.7" />
                                    <Button Margin="0,0,8,0" Padding="8,2" Content="{Binding PinButtonText}" Command="{Binding PinCommand}" />
                                    <Button Padding="8,2" Content="{Binding OpenButtonText}" Command="{Binding OpenCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="{Binding SnippetsHeaderText}" Margin="0,0,8,0">
                <ListBox ItemsSource="{Binding Snippets}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" Text="{Binding Name}" />
                                    <TextBlock Margin="0,2,0,0" Text="{Binding Snippet}" TextWrapping="Wrap" />
                                    <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                        <TextBlock Margin="0,0,12,0" Text="{Binding Source}" Opacity="0.75" />
                                        <Button Margin="0,0,8,0" Padding="8,2" Content="{Binding OpenButtonText}" Command="{Binding OpenCommand}" />
                                        <Button Padding="8,2" Content="{Binding DeleteButtonText}" Command="{Binding DeleteCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="{Binding ChatHistoryHeaderText}">
                <ListBox ItemsSource="{Binding ChatHistory}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" FontWeight="Bold" Text="{Binding Role}" />
                                        <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" Text="{Binding Timestamp}" Opacity="0.7" />
                                    </DockPanel>
                                    <TextBlock Margin="0,4,0,0" Text="{Binding Text}" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Opacity="0.7"
                                               Visibility="{Binding HasContextLabels, Converter={StaticResource BoolToVisConverter}}">
                                        <Run Text="{Binding ContextLabelsPrefixText}" />
                                        <Run Text="{Binding ContextLabelsJoinedDisplay}" />
                                    </TextBlock>
                                    <StackPanel Margin="0,6,0,0" Orientation="Horizontal"
                                                Visibility="{Binding IsActionableAssistant, Converter={StaticResource BoolToVisConverter}}">
                                        <Button Margin="0,0,8,0" Padding="8,2" Content="{Binding CopyAssistantButtonText}" Command="{Binding CopyAssistantCommand}" />
                                        <Button Margin="0,0,8,0" Padding="8,2" Content="{Binding AppendAssistantButtonText}" Command="{Binding AppendAssistantCommand}" />
                                        <Button Padding="8,2" Content="{Binding ReplaceAssistantButtonText}" Command="{Binding ReplaceAssistantCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>
    </Grid>
</DataTemplate>

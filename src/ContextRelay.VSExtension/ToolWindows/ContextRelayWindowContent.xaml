<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:styles="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
              xmlns:colors="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <DataTemplate.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <Style x:Key="SurfaceBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBorderBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="Opacity" Value="0.78" />
        </Style>

        <Style x:Key="ThemedButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>

        <Style x:Key="ThemedListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBorderBrushKey}}" />
        </Style>

        <Style x:Key="ThemedTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Static styles:VsResourceKeys.TextBoxStyleKey}}">
            <Setter Property="Background" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBorderBrushKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
        </Style>

        <Style x:Key="SuggestionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="SuggestionPopupListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource ThemedListBoxStyle}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>

        <Style x:Key="SuggestionListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>

        <Style x:Key="ThemedTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTabTextBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTabGradientBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTabBorderBrushKey}}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTabSelectedTabBrushKey}}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTabSelectedBorderBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTabSelectedTextBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTabMouseOverBackgroundGradientBrushKey}}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTabMouseOverBorderBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTabMouseOverTextBrushKey}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </DataTemplate.Resources>

    <Grid Margin="12"
          Background="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
          FocusManager.IsFocusScope="True"
          FocusManager.FocusedElement="{Binding ElementName=QueryTextBox}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SurfaceBorderStyle}" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding WindowTitleText}" Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
                <TextBlock Margin="0,3,0,0" Text="{Binding SignedInUserText}" Style="{StaticResource MutedTextStyle}" />
                <TextBlock Margin="0,3,0,0" Text="{Binding StatusMessage}" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
                <TextBlock Margin="0,3,0,0" Text="{Binding HelpText}" TextWrapping="Wrap" Style="{StaticResource MutedTextStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SurfaceBorderStyle}" Margin="0,0,10,0">
                <ListBox Style="{StaticResource ThemedListBoxStyle}" ItemsSource="{Binding ChatHistory}" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="8,8,8,0"
                                    Padding="10"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBorderBrushKey}}">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding Role}" Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
                                        <TextBlock DockPanel.Dock="Right" Margin="8,0,0,0" Text="{Binding Timestamp}" Style="{StaticResource MutedTextStyle}" />
                                    </DockPanel>
                                    <TextBlock Margin="0,6,0,0" Text="{Binding Text}" TextWrapping="Wrap" Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Style="{StaticResource MutedTextStyle}"
                                               Visibility="{Binding HasContextLabels, Converter={StaticResource BoolToVisConverter}}">
                                        <Run Text="{Binding ContextLabelsPrefixText}" />
                                        <Run Text="{Binding ContextLabelsJoinedDisplay}" />
                                    </TextBlock>
                                    <StackPanel Margin="0,8,0,0" Orientation="Horizontal"
                                                Visibility="{Binding IsActionableAssistant, Converter={StaticResource BoolToVisConverter}}">
                                        <Button Style="{StaticResource ThemedButtonStyle}" Margin="0,0,8,0" Padding="8,2" Content="{Binding CopyAssistantButtonText}" Command="{Binding CopyAssistantCommand}" />
                                        <Button Style="{StaticResource ThemedButtonStyle}" Margin="0,0,8,0" Padding="8,2" Content="{Binding AppendAssistantButtonText}" Command="{Binding AppendAssistantCommand}" />
                                        <Button Style="{StaticResource ThemedButtonStyle}" Margin="0,0,8,0" Padding="8,2" Content="{Binding ReplaceAssistantButtonText}" Command="{Binding ReplaceAssistantCommand}" />
                                        <Button Style="{StaticResource ThemedButtonStyle}" Padding="8,2" Content="{Binding ContinueAssistantButtonText}" Command="{Binding ContinueAssistantCommand}"
                                                Visibility="{Binding IsCopilotAssistant, Converter={StaticResource BoolToVisConverter}}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SurfaceBorderStyle}">
                <TabControl Background="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBorderBrushKey}}">
                    <TabItem Style="{StaticResource ThemedTabItemStyle}" Header="{Binding SearchResultsHeaderText}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Margin="8,8,8,0"
                                    Padding="8"
                                    Style="{StaticResource SurfaceBorderStyle}"
                                    Visibility="{Binding HasSearchSummary, Converter={StaticResource BoolToVisConverter}}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding SearchSummaryHeaderText}"
                                               Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding SearchSummary}"
                                               TextWrapping="Wrap"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>

                            <ListBox Grid.Row="1" Style="{StaticResource ThemedListBoxStyle}" ItemsSource="{Binding SearchResults}" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBorderBrushKey}}">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{Binding PinButtonText}" Command="{Binding PinCommand}" />
                                                    <MenuItem Header="{Binding CopyMenuText}" Command="{Binding CopyCommand}" />
                                                    <MenuItem Header="{Binding AppendToHandoffMenuText}" Command="{Binding AppendToHandoffCommand}" />
                                                    <Separator />
                                                    <MenuItem Header="{Binding OpenInBrowserMenuText}" Command="{Binding OpenCommand}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <DockPanel Grid.Row="0">
                                                    <TextBlock DockPanel.Dock="Left" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding SourceIcon}" Margin="0,0,4,0" Style="{StaticResource MutedTextStyle}" />
                                                        <TextBlock Text="{Binding SourceLabel}" Style="{StaticResource MutedTextStyle}" />
                                                    </StackPanel>
                                                </DockPanel>
                                                <TextBlock Grid.Row="1" Margin="0,4,0,0" Text="{Binding Snippet}" TextWrapping="Wrap" />
                                                <StackPanel Grid.Row="2" Margin="0,6,0,0" Orientation="Horizontal">
                                                    <TextBlock Margin="0,0,12,0" Text="{Binding Timestamp}" Style="{StaticResource MutedTextStyle}" />
                                                    <Button Style="{StaticResource ThemedButtonStyle}" Margin="0,0,8,0" Padding="8,2" Content="{Binding PinButtonText}" Command="{Binding PinCommand}" />
                                                    <Button Style="{StaticResource ThemedButtonStyle}" Padding="8,2" Content="{Binding OpenButtonText}" Command="{Binding OpenCommand}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>

                    <TabItem Style="{StaticResource ThemedTabItemStyle}" Header="{Binding SnippetsHeaderText}">
                        <ListBox Style="{StaticResource ThemedListBoxStyle}" ItemsSource="{Binding Snippets}" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBorderBrushKey}}">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                            <TextBlock Margin="0,2,0,0" Text="{Binding Snippet}" TextWrapping="Wrap" />
                                            <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                                <TextBlock Margin="0,0,4,0" Text="{Binding SourceIcon}" Style="{StaticResource MutedTextStyle}" />
                                                <TextBlock Margin="0,0,12,0" Text="{Binding SourceLabel}" Style="{StaticResource MutedTextStyle}" />
                                                <Button Style="{StaticResource ThemedButtonStyle}" Margin="0,0,8,0" Padding="8,2" Content="{Binding OpenButtonText}" Command="{Binding OpenCommand}" />
                                                <Button Style="{StaticResource ThemedButtonStyle}" Padding="8,2" Content="{Binding DeleteButtonText}" Command="{Binding DeleteCommand}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                    Margin="0,0,0,6"
                    Style="{StaticResource SurfaceBorderStyle}"
                    Visibility="{Binding IsCommandPopupOpen, Converter={StaticResource BoolToVisConverter}}">
                <StackPanel>
                    <TextBlock Margin="8,6,8,4" FontWeight="SemiBold" Text="{Binding CommandPopupHeaderText}" Style="{StaticResource MutedTextStyle}" />
                     <ListBox Style="{StaticResource SuggestionPopupListBoxStyle}" MaxHeight="220" BorderThickness="0"
                              ItemsSource="{Binding VisibleCommandSuggestions}"
                              SelectedItem="{Binding SelectedCommandSuggestion, Mode=TwoWay}"
                              ItemContainerStyle="{StaticResource SuggestionListBoxItemStyle}">
                         <ListBox.ItemTemplate>
                             <DataTemplate>
                                 <Button Style="{StaticResource SuggestionButtonStyle}" Command="{Binding ApplyCommand}">
                                     <StackPanel Margin="8,4">
                                         <StackPanel Orientation="Horizontal">
                                             <TextBlock Text="{Binding Icon}" Margin="0,0,4,0"
                                                        Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
                                             <TextBlock FontWeight="SemiBold" Text="{Binding Name}"
                                                        Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}" />
                                         </StackPanel>
                                         <TextBlock Margin="0,2,0,0" Text="{Binding Description}" TextWrapping="Wrap" Style="{StaticResource MutedTextStyle}" />
                                     </StackPanel>
                                 </Button>
                             </DataTemplate>
                         </ListBox.ItemTemplate>
                     </ListBox>
                </StackPanel>
            </Border>

            <Button Style="{StaticResource ThemedButtonStyle}" Grid.Row="1" Grid.Column="0"
                    Margin="0,0,8,0"
                    Padding="12,8"
                    Content="{Binding AddFilesButtonText}"
                    ToolTip="{Binding AddFilesToolTipText}"
                    Command="{Binding AddFilesCommand}"
                    IsEnabled="{Binding IsNotBusy}" />

            <TextBox x:Name="QueryTextBox"
                     Style="{StaticResource ThemedTextBoxStyle}" Grid.Row="1" Grid.Column="1"
                      Margin="0,0,8,0"
                      Padding="10,8"
                      Text="{Binding QueryText, UpdateSourceTrigger=PropertyChanged}"
                      ToolTip="{Binding SearchToolTipText}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding ConfirmQueryInputCommand}" />
                    <KeyBinding Key="Down" Command="{Binding MoveSelectionDownCommand}" />
                    <KeyBinding Key="Up" Command="{Binding MoveSelectionUpCommand}" />
                    <KeyBinding Key="Tab" Command="{Binding ApplyCommandSelectionCommand}" />
                    <KeyBinding Key="Escape" Command="{Binding CloseCommandPopupCommand}" />
                </TextBox.InputBindings>

            </TextBox>
            <Button Style="{StaticResource ThemedButtonStyle}" Grid.Row="1" Grid.Column="2" Padding="16,8" Content="{Binding SearchButtonText}" Command="{Binding SearchCommand}" IsEnabled="{Binding IsNotBusy}" />
        </Grid>
    </Grid>
</DataTemplate>

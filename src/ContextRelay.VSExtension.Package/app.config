<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <runtime>
    <!-- Binding redirects to resolve .NET 8.0 assembly references in .NET Framework 4.8 context -->
    <!-- When the in-process .NET 4.8 package loads the out-of-process .NET 8.0 extension,
         it encounters assemblies targeting .NET 8.0. These redirects ensure .NET Framework 4.8
         provides compatible older versions instead of failing with FileNotFoundException. -->

    <!-- System.Runtime is the core runtime library used by .NET 8.0 projects -->
    <bindingRedirect oldAssembly="System.Runtime" oldVersion="0.0.0.0-9.9.9.9" newVersion="4.2.2.0" />

    <!-- System.Collections provides generic collection types -->
    <bindingRedirect oldAssembly="System.Collections" oldVersion="0.0.0.0-9.9.9.9" newVersion="4.0.11.0" />

    <!-- System.Collections.Concurrent provides thread-safe collections -->
    <bindingRedirect oldAssembly="System.Collections.Concurrent" oldVersion="0.0.0.0-9.9.9.9" newVersion="4.0.12.0" />

    <!-- System.Diagnostics.TraceSource for diagnostic tracing -->
    <bindingRedirect oldAssembly="System.Diagnostics.TraceSource" oldVersion="0.0.0.0-9.9.9.9" newVersion="4.0.0.0" />

    <!-- System.ComponentModel.Annotations for data annotations -->
    <bindingRedirect oldAssembly="System.ComponentModel.Annotations" oldVersion="0.0.0.0-9.9.9.9" newVersion="4.2.1.0" />

    <!-- System.Reflection.Metadata for metadata reading -->
    <bindingRedirect oldAssembly="System.Reflection.Metadata" oldVersion="0.0.0.0-9.9.9.9" newVersion="1.4.2.0" />

    <!-- System.Text.Encodings.Web for web encoding -->
    <bindingRedirect oldAssembly="System.Text.Encodings.Web" oldVersion="0.0.0.0-9.9.9.9" newVersion="4.0.5.0" />

    <!-- System.Text.Json for JSON serialization (if used) -->
    <bindingRedirect oldAssembly="System.Text.Json" oldVersion="0.0.0.0-9.9.9.9" newVersion="4.0.1.0" />

    <!-- Newtonsoft.Json version compatibility (known to have version conflicts) -->
    <bindingRedirect oldAssembly="Newtonsoft.Json" oldVersion="0.0.0.0-9.9.9.9" newVersion="13.0.1.0" />
  </runtime>
</configuration>
